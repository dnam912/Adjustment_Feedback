<!DOCTYPE html>
<html>

    <head>
        <title>Aural Rehabilitation Database</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    </head>

    <body>
        <div class="container table-responsive mt-3 mb-3">
            <h1 class="text-center mt-2 mb-2">Welcome!</h1>
            <div style="display: flex;width: 100%; justify-content: space-between;">
                <a class="btn btn-md btn-primary" href="/">Back to dashboard</a>
                <a class="btn btn-md btn-primary" href="/events/create">Add new data point</a>
            </div>
            <table class="table table-striped table-bordered align-middle ml-3 mr-3 mt-3 mb-3">
                <thead class="table-dark">
                    <tr>
                        <th rowspan="2">ID</th>
                        <th rowspan="2">Date added</th>
                        <th rowspan="2">Date modified</th>
                        <th rowspan="2">Volume</th>
                        <th colspan="3" class="text-center">Frequency</th>
                        <th rowspan="2">Pain</th>
                        <th rowspan="2">Dullness</th>
                        <th rowspan="2">Environment Tags</th>
                        <th rowspan="2">Environment dB</th>
                        <th class="text-center" rowspan="2">Edit</th>
                        <th class="text-center" rowspan="2">Delete</th>
                    </tr>
                    <tr>
                        <th>Low</th>
                        <th>Medium</th>
                        <th>High</th>
                    </tr>
                </thead>

                <% for (let event of event_data) { %>
                    <tr>
                        <td>
                            <%= event.id %>
                        </td>
                        <td>
                            <%= new Date(event.date_added).toLocaleString() %>
                        </td>
                        <td>
                            <%= new Date(event.date_modified).toLocaleString() %>
                        </td>
                        <td>
                            <%= event.volume %>
                        </td>
                        <td>
                            <%= event.l_frequency %>
                        </td>
                        <td>
                            <%= event.m_frequency %>
                        </td>
                        <td>
                            <%= event.h_frequency %>
                        </td>
                        <td>
                            <%= event.pain %>
                        </td>
                        <td>
                            <%= event.dull %>
                        </td>
                        <td>
                            <%= event.env_tags %>
                        </td>
                        <td>
                            <%= event.env_dB %>
                        </td>
                        <td class="text-center"><a class="btn btn-sm btn-warning"
                                href="/events/update/<%= event.id %>"><span class="material-icons">edit</span></a></td>
                        <td class="text-center"><a class="btn btn-sm btn-danger"
                                href="/events/delete/<%= event.id %>"><span class="material-icons">delete</span></a>
                        </td>
                    </tr>
                    <% } %>
            </table>
        </div>

    </body>

</html>